# MQTT Connection Configuration
# Copy this file to .env and adjust variables as needed. Do not commit .env to version control.

MQTT_BROKER="tcp://broker.hivemq.com:1883"
MQTT_PORT=1883
MQTT_USER="your_mqtt_username"
MQTT_PASS="your_mqtt_password"
MQTT_CLIENT_ID="EmberRootNode01"
MQTT_TOPIC="emberroot/sensors"
